# ============================================================
# Examencoach Maatschappijwetenschappen - Omgevingsvariabelen
# Kopieer dit bestand naar '.env' en vul de waarden in.
# Commit NOOIT het .env bestand naar versiebeheer!
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Google Sheets ---
# Maak een Service Account aan in Google Cloud Console.
# Sla het JSON-sleutelbestand op als 'credentials.json' in de projectroot.
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=1ABCDEFGhijklmnopqrstuvwxyz1234567890

# --- App Instellingen ---
APP_TITLE=Examencoach Maatschappijwetenschappen
DATA_DIR=data/processed
PDF_DIR=data/pdfs

# --- E-mail (SMTP) ---
# Voor Gmail: maak een App-wachtwoord aan via myaccount.google.com/apppasswords
# (2FA moet aan staan). Gebruik het gegenereerde 16-cijferige wachtwoord hieronder.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jouw-adres@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_RECIPIENT=wgn@fioretti.nl
